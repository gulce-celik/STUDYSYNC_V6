# =============================================================================
# StudySync AI servisi — ORNEK DOSYA (bu dosyayi Git'e commitleyebilirsin)
# =============================================================================
#
# NE YAPMALISIN? (her gelistirici kendi bilgisayarinda, bir kez):
#
#   1) Bu dosyayi KOPYALA ve adini ".env" yap (aynı klasorde: backend_python/)
#      Windows PowerShell:
#        cd backend_python
#        Copy-Item .env.example .env
#
#      Mac/Linux:
#        cp .env.example .env
#
#   2) ".env" dosyasini ac — asagidaki GEMINI_API_KEY satirina KENDI anahtarini yaz.
#      Anahtar almak: https://aistudio.google.com/apikey  → "Create API key"
#      (Ucretsiz kotayla baslanir; key'i kimseyle paylasmayin, GitHub'a yuklemeyin.)
#
#   3) Python bagimliliklarini kur ve servisi calistir:
#        python -m venv .venv
#        .venv\Scripts\activate          (Windows)
#        source .venv/bin/activate       (Mac/Linux)
#        pip install -r requirements.txt
#        uvicorn app.main:app --host 0.0.0.0 --port 8090 --reload
#
#   4) Ayri terminalde Java backend:
#        cd backend_java
#        .\mvnw.cmd spring-boot:run        (Windows)
#
#   5) Flutter app:
#        cd mobile_flutter
#        flutter run
#
# ONEMLI:
#   - ".env" dosyasi Git'e GITMEZ (.gitignore) — herkes kendi key'ini yazar.
#   - Python calismazsa app yine acilir; AI kartlari basit modda (scoring) gelir.
#   - Canli sunucuda (Render) key, panelden Environment Variable olarak verilir.
#
# =============================================================================

# ZORUNLU (gercek AI metinleri icin): Google Gemini API key
# Ornek format: AIzaSy................................
GEMINI_API_KEY=buraya_kendi_api_keyini_yapistir

# Opsiyonel: model adi (degistirmesen de olur)
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_MODEL_FALLBACK=gemini-2.0-flash-lite

# Kota korumasi (saniye) — ayni ogrenci verisi icin cache, istekler arasi min aralik
GEMINI_CACHE_TTL_SECONDS=600
GEMINI_MIN_INTERVAL_SECONDS=60
GEMINI_COOLDOWN_SECONDS=300

# Opsiyonel: bu servisin dinledigi port (Java varsayilan: http://localhost:8090)
AI_SERVICE_PORT=8090
